#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

secret_scan() {
	if command -v pwsh >/dev/null 2>&1; then
		pwsh -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/check-staged-secrets.ps1"
		return $?
	fi
	if command -v powershell.exe >/dev/null 2>&1; then
		powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/check-staged-secrets.ps1"
		return $?
	fi
	bash "$REPO_ROOT/scripts/check-staged-secrets.sh"
}

if secret_scan; then
	:
else
	scan_rc=$?
	exit "$scan_rc"
fi

if command -v pwsh >/dev/null 2>&1; then
	pwsh -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/quality-gate.ps1"
	exit $?
fi

if command -v powershell.exe >/dev/null 2>&1; then
	powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$REPO_ROOT/scripts/quality-gate.ps1"
	exit $?
fi

bash "$REPO_ROOT/scripts/quality-gate.sh"
